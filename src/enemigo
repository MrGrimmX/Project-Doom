#pragma once

#include "Animation.h"

enum class EnemyState
{
    Idle,
    Attack,
    Death
};

class Enemy
{
private:

    sf::Sprite sprite;

    Animation idleAnim;
    Animation attackAnim;
    Animation deathAnim;

    EnemyState state;

    int health;

public:

    Enemy()
        : idleAnim(0.15f, true),
          attackAnim(0.08f, true),
          deathAnim(0.10f, false)
    {
        state = EnemyState::Idle;
        health = 100;
    }

    bool load(
        std::string idleName,
        int idleFrames,

        std::string attackName,
        int attackFrames,

        std::string deathName,
        int deathFrames)
    {
        bool ok = true;

        ok &= idleAnim.loadFrames(idleName, idleFrames);
        ok &= attackAnim.loadFrames(attackName, attackFrames);
        ok &= deathAnim.loadFrames(deathName, deathFrames);

        sprite.setTexture(idleAnim.getTexture());

        return ok;
    }

    void setPosition(float x, float y)
    {
        sprite.setPosition(x, y);
    }

    void setScale(float x, float y)
    {
        sprite.setScale(x, y);
    }

    void attack()
    {
        if(state == EnemyState::Death)
            return;

        state = EnemyState::Attack;
        attackAnim.reset();
    }

    void idle()
    {
        if(state == EnemyState::Death)
            return;

        state = EnemyState::Idle;
    }

    void damage(int dmg)
    {
        if(state == EnemyState::Death)
            return;

        health -= dmg;

        if(health <= 0)
        {
            state = EnemyState::Death;
            deathAnim.reset();
        }
    }

    void update(float dt)
    {
        switch(state)
        {
        case EnemyState::Idle:

            idleAnim.update(dt);
            sprite.setTexture(idleAnim.getTexture());

            break;

        case EnemyState::Attack:

            attackAnim.update(dt);
            sprite.setTexture(attackAnim.getTexture());

            break;

        case EnemyState::Death:

            deathAnim.update(dt);
            sprite.setTexture(deathAnim.getTexture());

            break;
        }
    }

    void draw(sf::RenderWindow& window)
    {
        window.draw(sprite);
    }

    EnemyState getState() const
    {
        return state;
    }
};