#pragma once
#include <SFML/Graphics.hpp>
#include <vector>
#include <string>

class Animation
{
private:
    std::vector<sf::Texture> frames;
    float frameTime;
    float timer;
    int currentFrame;
    bool loop;

public:

    Animation(float speed = 0.1f, bool looping = true)
        : frameTime(speed),
          timer(0.f),
          currentFrame(0),
          loop(looping)
    {
    }

    bool loadFrames(const std::string& prefix, int totalFrames)
    {
        frames.clear();

        for(int i = 0; i < totalFrames; i++)
        {
            sf::Texture texture;

            std::string path =
                "Mutants/" + prefix + std::to_string(i) + ".png";

            if(!texture.loadFromFile(path))
                return false;

            texture.setSmooth(true);
            frames.push_back(texture);
        }

        return true;
    }

    void update(float dt)
    {
        if(frames.empty())
            return;

        timer += dt;

        if(timer >= frameTime)
        {
            timer = 0.f;

            currentFrame++;

            if(currentFrame >= frames.size())
            {
                if(loop)
                    currentFrame = 0;
                else
                    currentFrame = frames.size() - 1;
            }
        }
    }

    const sf::Texture& getTexture() const
    {
        return frames[currentFrame];
    }

    void reset()
    {
        currentFrame = 0;
        timer = 0.f;
    }

    bool finished() const
    {
        return !loop && currentFrame == frames.size() - 1;
    }
};